; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be manually edited.

[application]

config/name="Immortal Sect"
config/description="Cultivation Sect Tycoon - Idle Game"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.4")

[autoload]

BigNumber="*res://autoload/big_number.gd"
GameData="*res://autoload/game_data.gd"
GameManager="*res://autoload/game_manager.gd"
HallManager="*res://autoload/hall_manager.gd"
ElderManager="*res://autoload/elder_manager.gd"
PrestigeManager="*res://autoload/prestige_manager.gd"
AlchemyManager="*res://autoload/alchemy_manager.gd"
DaoPathManager="*res://autoload/dao_path_manager.gd"
ChallengeManager="*res://autoload/challenge_manager.gd"
MandateManager="*res://autoload/mandate_manager.gd"
DiscipleManager="*res://autoload/disciple_manager.gd"
DungeonManager="*res://autoload/dungeon_manager.gd"
LegacyManager="*res://autoload/legacy_manager.gd"
MissionManager="*res://autoload/mission_manager.gd"
SaveManager="*res://autoload/save_manager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"

[rendering]

renderer/rendering_method="gl_compatibility"
